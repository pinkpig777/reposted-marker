{
  "manifest_version": 3,
  "name": "LinkedIn Reposted Marker",
  "version": "0.3.0",
  "description": "Highlights reposted LinkedIn job listings in the jobs list and detail panel.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background/index.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "shared/constants.js",
        "shared/utils.js",
        "content/job-id.js",
        "content/cache.js",
        "content/card-registry.js",
        "content/detector.js",
        "content/styler.js",
        "content/scanner.js",
        "content/prefetch.js",
        "content/messaging.js",
        "content/observer.js",
        "content/index.js"
      ],
      "css": [
        "styles/injected.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
